<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="RestAssured API Test Suite" verbose="1" parallel="classes" thread-count="3">

    <listeners>
        <listener class-name="com.api.framework.listeners.AllureTestListener"/>
        <listener class-name="com.api.framework.listeners.ExtentReportManager"/>
        <listener class-name="com.api.framework.listeners.RetryListener"/>
    </listeners>

    <!-- ── Smoke: quick sanity checks on critical paths ── -->
    <test name="Smoke Tests" group-by-instances="true">
        <groups>
            <run>
                <include name="smoke"/>
            </run>
        </groups>
        <classes>
            <class name="com.api.framework.tests.PostsApiTest"/>
            <class name="com.api.framework.tests.UsersApiTest"/>
            <class name="com.api.framework.tests.TodosApiTest"/>
            <class name="com.api.framework.tests.CommentsApiTest"/>
        </classes>
    </test>

    <!-- ── Contract: JSON schema validation ── -->
    <test name="Contract Tests">
        <groups>
            <run>
                <include name="contract"/>
            </run>
        </groups>
        <classes>
            <class name="com.api.framework.tests.SchemaValidationTest"/>
        </classes>
    </test>

    <!-- ── Regression: full suite ── -->
    <test name="Regression Tests">
        <classes>
            <class name="com.api.framework.tests.PostsApiTest"/>
            <class name="com.api.framework.tests.UsersApiTest"/>
            <class name="com.api.framework.tests.NegativeApiTest"/>
            <class name="com.api.framework.tests.TodosApiTest"/>
            <class name="com.api.framework.tests.CommentsApiTest"/>
            <class name="com.api.framework.tests.SchemaValidationTest"/>
        </classes>
    </test>

</suite>
