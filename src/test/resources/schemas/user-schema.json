{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "User",
  "description": "Schema for a single User object from JSONPlaceholder",
  "type": "object",
  "required": ["id", "name", "username", "email"],
  "properties": {
    "id": {
      "type": "integer",
      "minimum": 1
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "username": {
      "type": "string",
      "minLength": 1
    },
    "email": {
      "type": "string",
      "format": "email"
    },
    "phone": {
      "type": "string"
    },
    "website": {
      "type": "string"
    },
    "address": {
      "type": "object"
    },
    "company": {
      "type": "object"
    }
  }
}
