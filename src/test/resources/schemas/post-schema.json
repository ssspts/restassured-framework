{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Post",
  "description": "Schema for a single Post object from JSONPlaceholder",
  "type": "object",
  "required": ["id", "userId", "title", "body"],
  "properties": {
    "id": {
      "type": "integer",
      "minimum": 1
    },
    "userId": {
      "type": "integer",
      "minimum": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "body": {
      "type": "string",
      "minLength": 1
    }
  },
  "additionalProperties": false
}
